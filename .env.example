# ─────────────────────────────────────────────────────────────────
# ANTHROPIC — Chatbot IA (Ana Quiroga)
# Consíguela en https://console.anthropic.com
# ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...


# ─────────────────────────────────────────────────────────────────
# GO HIGH LEVEL (GHL) — CRM & Calendario
#
# Dónde encontrar cada valor:
#   GHL_API_KEY          → GHL > Settings > API Keys > Create Key
#   GHL_LOCATION_ID      → GHL > Settings > Business Profile > Location ID
#   GHL_CALENDAR_ID      → GHL > Calendars > [tu calendario] > Settings > Calendar ID
#   GHL_ASSIGNED_USER_ID → GHL > Settings > My Staff > [Ana] > copiar ID (opcional)
#
# Sin estas variables el sitio funciona igual,
# solo no se registrarán leads/citas en GHL.
# ─────────────────────────────────────────────────────────────────
GHL_API_KEY=eyJhbGci...
GHL_LOCATION_ID=xxxxxxxxxxxxxxxx
GHL_CALENDAR_ID=xxxxxxxxxxxxxxxx
GHL_ASSIGNED_USER_ID=xxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────
# GOOGLE MAPS — Mapa de ubicación en landings de proyectos
#
# Dónde obtenerla:
#   Google Cloud Console → APIs & Services → Credentials → Create Key
#   Habilitar: Maps JavaScript API
#   Restringir a tu dominio en producción
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
